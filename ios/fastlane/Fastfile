default_platform(:ios)

platform :ios do
  desc "Run tests"
  lane :test do
    run_tests(
      project: "MyApp.xcodeproj",
      scheme: "MyApp",
      devices: ["iPhone 16"],
      clean: true,
      code_coverage: true
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    # Increment build number
    increment_build_number(
      build_number: ENV["BUILD_NUMBER"] || (latest_testflight_build_number + 1).to_s
    )

    # Build
    build_app(
      project: "MyApp.xcodeproj",
      scheme: "MyApp",
      export_method: "app-store",
      clean: true
    )

    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      api_key: app_store_connect_api_key
    )
  end

  desc "Build for App Store submission"
  lane :release do
    increment_build_number(
      build_number: (latest_testflight_build_number + 1).to_s
    )

    build_app(
      project: "MyApp.xcodeproj",
      scheme: "MyApp",
      export_method: "app-store",
      clean: true
    )

    upload_to_app_store(
      skip_metadata: false,
      skip_screenshots: true,
      submit_for_review: false,
      api_key: app_store_connect_api_key
    )
  end

  desc "Sync code signing certificates"
  lane :certificates do
    match(type: "development")
    match(type: "appstore")
  end

  private_method
  def app_store_connect_api_key
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY"],
      is_key_content_base64: true
    )
  end
end
